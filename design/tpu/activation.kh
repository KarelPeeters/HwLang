import fp_util.Float;

// Parameterizable activation unit for Float(E, M)
pub module activation_unit(E: uint, M: uint, N: uint) ports(
    clk: in clock,
    data_in: in sync(clk) [N]Float(E, M),
    data_out: out sync(clk) [N]Float(E, M),
) {
    clocked(clk) {
        reg wire data_out = undef;
        for (i in 0..N) {
            data_out[i] = data_in[i].relu();
        }
    }
}
