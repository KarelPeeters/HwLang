// Activation function post-processing unit
// Currently only implements ReLU on f32 values

pub module activation_unit(N: uint) ports(
    clk: in clock,
    data_in: in sync(clk) [N]fp_util.F32,
    data_out: out sync(clk) [N]fp_util.F32,
) {
    clocked(clk) {
        reg wire data_out = [fp_util.f32_zero()] * N;
        for (i in 0..N) {
            data_out[i] = fp_util.f32_relu(data_in[i]);
        }
    }
}
